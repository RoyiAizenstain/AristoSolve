{
  "info": {
    "name": "AristoSolve",
    "description": "AristoSolve API — AI-guided coding interview platform. All routes are under /api. Use x-user-role and x-user-id headers to simulate authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST login (candidate)",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"carol@example.com\",\"password\":\"candidate123\"}" }
          }
        },
        {
          "name": "POST login (company)",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"bob@example.com\",\"password\":\"company123\"}" }
          }
        },
        {
          "name": "POST login (admin)",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"alice@example.com\",\"password\":\"admin123\"}" }
          }
        },
        {
          "name": "POST logout",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/auth/logout",
            "header": []
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET all users (admin)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/users",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "x-user-id", "value": "1" }
            ]
          }
        },
        {
          "name": "GET /users/me",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/users/me",
            "header": [
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ]
          }
        },
        {
          "name": "GET user by ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/users/3",
            "header": [
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ]
          }
        },
        {
          "name": "POST register user",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"firstName\":\"Test\",\"lastName\":\"User\",\"email\":\"test@example.com\",\"password\":\"test123\",\"userRole\":\"candidate\"}" }
          }
        },
        {
          "name": "PUT update user",
          "request": {
            "method": "PUT",
            "url": "http://localhost:3000/api/users/3",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ],
            "body": { "mode": "raw", "raw": "{\"firstName\":\"Carol Updated\"}" }
          }
        },
        {
          "name": "DELETE user (admin)",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:3000/api/users/5",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "x-user-id", "value": "1" }
            ]
          }
        }
      ]
    },
    {
      "name": "Problems",
      "item": [
        {
          "name": "GET all problems (admin — sees all)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/problems",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "x-user-id", "value": "1" }
            ]
          }
        },
        {
          "name": "GET all problems (candidate — public only)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/problems",
            "header": [
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ]
          }
        },
        {
          "name": "GET problems filtered by difficulty",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/problems?difficulty=easy",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "x-user-id", "value": "1" }
            ]
          }
        },
        {
          "name": "GET problem by ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/problems/3",
            "header": [
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ]
          }
        },
        {
          "name": "POST create problem (company)",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/problems",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "company" },
              { "key": "x-user-id", "value": "2" }
            ],
            "body": { "mode": "raw", "raw": "{\"title\":\"New Problem\",\"difficulty\":\"easy\",\"topic\":\"arrays\",\"type\":\"algorithm\",\"description\":\"Solve this problem.\",\"isPublic\":false,\"evalPrompt\":\"Focus on time complexity.\"}" }
          }
        },
        {
          "name": "PUT update problem (company — own)",
          "request": {
            "method": "PUT",
            "url": "http://localhost:3000/api/problems/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "company" },
              { "key": "x-user-id", "value": "2" }
            ],
            "body": { "mode": "raw", "raw": "{\"title\":\"Two Sum (Updated)\"}" }
          }
        },
        {
          "name": "DELETE problem (admin)",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:3000/api/problems/1",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "x-user-id", "value": "1" }
            ]
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "GET conversations for problem (candidate)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/conversations?problemId=3",
            "header": [
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ]
          }
        },
        {
          "name": "GET conversation by ID with messages",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/conversations/1",
            "header": [
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ]
          }
        },
        {
          "name": "POST start conversation",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/conversations",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ],
            "body": { "mode": "raw", "raw": "{\"userId\":3,\"problemId\":3,\"language\":\"python\"}" }
          }
        },
        {
          "name": "PUT end conversation (triggers AI evaluation)",
          "request": {
            "method": "PUT",
            "url": "http://localhost:3000/api/conversations/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ],
            "body": { "mode": "raw", "raw": "{\"endedAt\":\"2026-06-21T12:00:00Z\"}" }
          }
        },
        {
          "name": "POST send message",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/conversations/1/messages",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ],
            "body": { "mode": "raw", "raw": "{\"role\":\"user\",\"content\":\"What is a hash map?\"}" }
          }
        }
      ]
    },
    {
      "name": "Progress (Assignments)",
      "item": [
        {
          "name": "GET my progress (candidate)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/progress",
            "header": [
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ]
          }
        },
        {
          "name": "POST assign problem to candidate (company)",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/progress",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "company" },
              { "key": "x-user-id", "value": "2" }
            ],
            "body": { "mode": "raw", "raw": "{\"userId\":3,\"problemId\":1,\"status\":\"in_progress\",\"deadline\":\"2026-07-01\"}" }
          }
        },
        {
          "name": "PUT mark progress completed",
          "request": {
            "method": "PUT",
            "url": "http://localhost:3000/api/progress/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ],
            "body": { "mode": "raw", "raw": "{\"status\":\"completed\"}" }
          }
        }
      ]
    },
    {
      "name": "Evaluations",
      "item": [
        {
          "name": "GET evaluations (company — sees own candidates)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/evaluations",
            "header": [
              { "key": "x-user-role", "value": "company" },
              { "key": "x-user-id", "value": "2" }
            ]
          }
        },
        {
          "name": "GET evaluations (admin — sees all)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/evaluations",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "x-user-id", "value": "1" }
            ]
          }
        }
      ]
    },
    {
      "name": "Settings",
      "item": [
        {
          "name": "GET settings",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/settings",
            "header": [
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ]
          }
        },
        {
          "name": "PUT update settings",
          "request": {
            "method": "PUT",
            "url": "http://localhost:3000/api/settings",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "candidate" },
              { "key": "x-user-id", "value": "3" }
            ],
            "body": { "mode": "raw", "raw": "{\"displayName\":\"Carol Chen\",\"theme\":\"dark\",\"emailNotifications\":true}" }
          }
        }
      ]
    }
  ]
}
